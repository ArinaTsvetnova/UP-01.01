<Window x:Class="UP01._01.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UP01._01"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="40"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Frame Grid.Row="0" Grid.Column="1" x:Name="MainFrame" Source="Pages/LoginPage.xaml" NavigationUIVisibility="Hidden" Navigated="MainFrame_Navigated"/>
        <Border VerticalAlignment="Top" x:Name="sidebar" Grid.Column="0" Grid.Row="0" Background="#FFDE73" BorderThickness="0,0,1,0" Height="270">
            <StackPanel VerticalAlignment="Top">
                <Image Source="/Images/ikonka.jpg" HorizontalAlignment="Center" Height="30"/>
                <Button x:Name="CatalogPage" ToolTip="Каталог книг" Click="CatalogPage_Click" Height="40">
                    <Image Source="/Images/catalog.jpg"/>
                </Button>
                <Button x:Name="ListPage" ToolTip="Мои списки" Click="ListPage_Click" Height="40">
                    <Image Source="/Images/list.jpg"/>
                </Button>
                <Button x:Name="Author" ToolTip="Кабинет автора"  Click="Author_Click" Height="40">
                    <Image Source="/Images/author.jpg"/>
                </Button>
                <Button x:Name="Admin" ToolTip="Администрирование" Click="Admin_Click" Height="40">
                    <Image Source="/Images/admin.jpg"/>
                </Button>
                <Button x:Name="Profile" ToolTip="Профиль" Click="Profile_Click" Height="40">
                    <Image Source="/Images/profile.jpg"/>
                </Button>
                <Button x:Name="Exit" ToolTip="Выйти" Click="Exit_Click" Height="40">
                    <Image Source="/Images/exit.jpg"/>
                </Button>
            </StackPanel>
        </Border>
        <Border x:Name="error" Grid.Row="0" Grid.Column="0" Background="#FF0000" BorderThickness="1" CornerRadius="5" Visibility="Collapsed"/>
    </Grid>
</Window>
