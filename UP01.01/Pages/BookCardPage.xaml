<Page x:Class="UP01._01.Pages.BookCardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UP01._01.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="BookCardPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="name" Text="{Binding books.Name}" FontSize="20" HorizontalAlignment="Center" Grid.Row="0"/>
        <StackPanel Grid.Row="1">
            <Image Source="{Binding books.Image}" Grid.Row="1" Height="100"/>
            <TextBlock x:Name="author" Margin="5" Text="{Binding books.Users.Name}" FontSize="12" HorizontalAlignment="Left"/>
            <TextBlock x:Name="rating" Margin="5" Text="{Binding books.Rating}" FontSize="12" HorizontalAlignment="Left"/>
            <TextBlock x:Name="ganre" FontSize="12" Margin="5" HorizontalAlignment="Left"/>
            <TextBlock x:Name="opisanie" Text="{Binding books.Description}" Margin="5" TextWrapping="Wrap" FontSize="12" HorizontalAlignment="Left"/>
        </StackPanel>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="Read" Content="Читать" Width="90" Height="30" Click="Read_Click" Margin="5"/>
            <Button x:Name="Add" Content="Добавить себе" Width="90" Height="30" Click="Add_Click" Margin="5"/>
            <Button x:Name="Block" Content="Заблокировать" Visibility="Collapsed" Width="90" Height="30" Click="Block_Click" Margin="5"/>
            <Button x:Name="Unblock" Content="Разблокировать" Visibility="Collapsed" Width="90" Height="30" Click="Unblock_Click"  Margin="5"/>
        </StackPanel>
        <StackPanel Grid.Row="3">
            <TextBlock Text="Недовольны автором или книгой? Напишите отзыв или оставьте жалобу!" HorizontalAlignment="Center"/>
            <Button x:Name="AlBook" Content="Жалоба на книгу" Width="110" Height="30" Margin="5" Click="AlBook_Click"/>
            <Button x:Name="AlAuthor" Content="Жалоба на автора" Width="110" Height="30" Margin="5" Click="AlAuthor_Click"/>
            <Button x:Name="BookRewie" Content="Оставить отзыв" Width="110" Height="30" Margin="5" Click="BookRewie_Click"/>
        </StackPanel>
        <ListBox x:Name="Rewie" Width="800" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Visible" Grid.Row="4" d:ItemsSource="{d:SampleData ItemCount=5}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Width="800">
                        <TextBlock Text="{Binding Users.Name}" Margin="5"/>
                        <TextBlock Text="{Binding Rating}" Margin="5"/>
                        <TextBlock Text="{Binding Text}" Margin="5" TextWrapping="Wrap"/>
                        <Button x:Name="AligRew" Content="Жалоба" Width="80" Height="30" Visibility="Collapsed" Click="AligRew_Click"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
        </ListBox>
    </Grid>
</Page>
