<Page x:Class="UP01._01.Pages.AddBookPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UP01._01.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddBookPage">

    <Grid>
        <StackPanel>
            <TextBlock x:Name="priv" FontSize="17" HorizontalAlignment="Left" Margin="10" VerticalAlignment="Top"/>
            <Button Content="Заброшено" Height="40" Width="100" HorizontalAlignment="Left" Margin="10" VerticalAlignment="Top" Click="Button_Click"/>
            <Button Content="В планах" Height="40" Width="100" HorizontalAlignment="Left" Margin="10" VerticalAlignment="Top" Click="Button_Click1"/>
            <Button Content="Читаю" Height="40" Width="100" HorizontalAlignment="Left" Margin="10" VerticalAlignment="Top" Click="Button_Click2"/>
            <Button Content="Прочитано" Height="40" Width="100" HorizontalAlignment="Left" Margin="10" VerticalAlignment="Top" Click="Button_Click3"/>
        </StackPanel>
    </Grid>
</Page>
