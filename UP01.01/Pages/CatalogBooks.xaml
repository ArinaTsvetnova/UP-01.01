<Page x:Class="UP01._01.Pages.CatalogBooks"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UP01._01.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CatalogBooks">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="5">
            <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="5"/>
            <TextBox x:Name="Search" Width="230" Height="30" VerticalContentAlignment="Center" Margin="0,0,5,0"/>
            <Button Content="Найти" Width="80" Height="30" Click="BtnSearch_Click" Margin="0,0,5,0"/>
            <TextBlock Text="Сортировка:" VerticalAlignment="Center" Margin="5"/>
            <ComboBox x:Name="CbSort" Width="120" Height="30" SelectionChanged="CbSort_SelectionChanged" Margin="0,0,5,0"/>
            <TextBlock Text="Жанр:" VerticalAlignment="Center" Margin="5"/>
            <ComboBox x:Name="CbGenreFilter" Width="120" Height="30" SelectionChanged="CbGenreFilter_SelectionChanged"/>
        </StackPanel>

        <ListBox x:Name="LbBooks" Height="370"  ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Visible" Grid.Row="1" d:ItemsSource="{d:SampleData ItemCount=5}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Width="200">
                        <Image Source="{Binding Image}" />
                        <TextBlock Text="{Binding Name}"/>
                        <TextBlock Text="{Binding Users.Name}"/>
                        <TextBlock Text="{Binding Rating}"/>
                        <Button x:Name="BookCard" Content="Подробнее" Width="90" Height="40" Click="BookCard_Click"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
        </ListBox>
    </Grid>
</Page>
